#include <WiFi.h>
#include <WebServer.h>
#include <ESP32Servo.h>
#include <Adafruit_NeoPixel.h>
#include "DHT.h"

#define FLAME_PIN   34
#define GAS_PIN     35
#define PIR_PIN     27
#define RELAY_PIN   25
#define SERVO_PIN   14
#define BUZZER_PIN  12
#define LED_PIN     13
#define DHT_PIN     26

#define DHTTYPE DHT22
#define LED_COUNT 1
#define GAS_THRESHOLD 1800

Servo scanServo;
WebServer server(80);
Adafruit_NeoPixel pixel(LED_COUNT, LED_PIN, NEO_GRB + NEO_KHZ800);
DHT dht(DHT_PIN, DHTTYPE);

bool flameDetected = false;
bool gasDetected = false;
bool humanDetected = false;

float temperature = 0;
float humidity = 0;

const char* ap_ssid = "ESP32_FIRE_SYSTEM";
const char* ap_password = "12345678";

void setLED(uint8_t r, uint8_t g, uint8_t b) {
  pixel.setPixelColor(0, pixel.Color(r, g, b));
  pixel.show();
}

void handleRoot() {

  String page = "<html><head>";
  page += "<meta name='viewport' content='width=device-width, initial-scale=1'>";
  page += "<style>";
  page += "body{font-family:Arial;text-align:center;background:#f4f4f4}";
  page += "h2{color:red}";
  page += ".box{background:white;padding:20px;margin:20px;border-radius:10px}";
  page += "</style></head><body>";

  page += "<h2>ESP32 Fire Detection System</h2>";

  page += "<div class='box'>";
  page += "<b>Flame:</b> " + String(flameDetected ? "YES" : "NO") + "<br>";
  page += "<b>Gas:</b> " + String(gasDetected ? "YES" : "NO") + "<br>";
  page += "<b>Human:</b> " + String(humanDetected ? "YES" : "NO") + "<br>";
  page += "<b>Temperature:</b> " + String(temperature) + " C<br>";
  page += "<b>Humidity:</b> " + String(humidity) + " %<br>";
  page += "<b>Pump:</b> " + String(digitalRead(RELAY_PIN) ? "ON" : "OFF") + "<br>";
  page += "</div>";

  page += "</body></html>";

  server.send(200, "text/html", page);
}

void setup() {

  Serial.begin(115200);

  pinMode(FLAME_PIN, INPUT);
  pinMode(PIR_PIN, INPUT);
  pinMode(RELAY_PIN, OUTPUT);
  pinMode(BUZZER_PIN, OUTPUT);

  digitalWrite(RELAY_PIN, LOW);
  digitalWrite(BUZZER_PIN, LOW);

  scanServo.attach(SERVO_PIN);

  pixel.begin();
  setLED(0,255,0);   

  dht.begin();

  WiFi.mode(WIFI_AP);
  WiFi.softAP(ap_ssid, ap_password);

  Serial.println("Hotspot started");
  Serial.println(WiFi.softAPIP());

  server.on("/", handleRoot);
  server.begin();
}

void loop() {

  server.handleClient();

  humanDetected = digitalRead(PIR_PIN);

  int gasValue = analogRead(GAS_PIN);
  gasDetected = gasValue > GAS_THRESHOLD;

  temperature = dht.readTemperature();
  humidity = dht.readHumidity();

  if (!flameDetected) {

    for(int angle = 0; angle <= 180; angle += 5) {

      scanServo.write(angle);
      delay(25);

      if(digitalRead(FLAME_PIN) == LOW) {
        flameDetected = true;
        break;
      }
    }
  }

  if(digitalRead(FLAME_PIN) == LOW) {

    flameDetected = true;

    digitalWrite(RELAY_PIN, HIGH);  
    digitalWrite(BUZZER_PIN, HIGH);  

    if(humanDetected)
      setLED(128,0,128);
    else
      setLED(255,0,0);  
  }

  if(!flameDetected && gasDetected) {

    digitalWrite(BUZZER_PIN, HIGH);
    setLED(255,255,0); 
  }

  if(!flameDetected && !gasDetected) {

    digitalWrite(BUZZER_PIN, LOW);
    setLED(0,0,255); 
  }

  delay(200);
}
